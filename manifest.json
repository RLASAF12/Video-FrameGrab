{
  "manifest_version": 3,
  "name": "Video FrameGrab",
  "version": "2.0.0",
  "description": "Automatically capture clean screenshots from any HTML5 video at a configurable interval. Downloads all frames as a single ZIP.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "toast.css"
      ],
      "js": [
        "minizip.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}